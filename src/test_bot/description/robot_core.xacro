<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1" />
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1" />
    </material>

    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <!-- BASE LINK -->
    <link name="base_link"/>

    <!-- BASE_FOOTPRINT LINK -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- FIX: el original tenÃ­a '/' como contenido del link, que es texto suelto invalido. -->
    <link name="base_footprint"/>

    <!-- CHASSIS LINK -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.15 0 0.075"/>
            <geometry>
                <box size ="0.16 0.2 0.1"/>
            </geometry>
            <material name="white"/>
        </visual>
        <!-- FIX: collision igualada a visual (antes 0.16/0.075 vs 0.2/0.19/0.1, inconsistente) -->
        <collision>
            <origin xyz="0.15 0 0.075"/>
            <geometry>
                <box size ="0.16 0.2 0.1"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.16" y="0.2" z="0.1">
            <origin xyz="0.15 0 0.075" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- LEFT WHEEL LINK -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.113 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1"/>
        <!-- FIX: damping evita micro-movimientos espurios del simulador en reposo -->
        <dynamics damping="0.05" friction="0.01"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius ="0.035" length="0.026"/>
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius ="0.035" length="0.026"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.026" radius="0.035">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <!-- FIX: fricciÃ³n explÃ­cita en ruedas. Sin esto Gazebo usa valores por defecto
         que combinados con el caster a mu=0.001 y un COM ligeramente delantero hacen
         que el robot resbale hacia adelante en reposo. -->
    <gazebo reference="left_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
    </gazebo>

    <!-- RIGHT WHEEL LINK -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.113 0" rpy="${pi/2} 0 0" />
        <axis xyz="0 0 -1"/>
        <dynamics damping="0.05" friction="0.01"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius ="0.035" length="0.026"/>
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius ="0.035" length="0.026"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.026" radius="0.035">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
    </gazebo>

    <!-- CASTER WHEEL LINK -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel"/>
        <origin xyz="0.20 0 -0.006"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.029"/>
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.029"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.029">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel">
        <material>Gazebo/Black</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

</robot>